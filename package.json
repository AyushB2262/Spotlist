{
  "name": "spotlist",
  "version": "1.0.0",
  "description": "Spotlist Playlist Sync Agent",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run watch-main\" \"vite\" \"sleep 2 && electron .\"",
    "build": "npm run compile-main && vite build",
    "compile-main": "tsc -p tsconfig.main.json",
    "watch-main": "tsc -w -p tsconfig.main.json",
    "start": "electron .",
    "test": "npm run compile-main && node dist/main/sync.test.js",
    "package": "npm run build && electron-builder"
  },
  "keywords": [
    "spotify",
    "playlist",
    "sync",
    "electron"
  ],
  "author": "Ayush",
  "license": "ISC",
  "dependencies": {
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
